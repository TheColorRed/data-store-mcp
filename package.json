{
  "name": "data-store-mcp",
  "displayName": "Data Store MCP",
  "description": "Use AI to connect to different data stores using the Model Context Protocol (MCP).",
  "version": "1.8.0",
  "publisher": "TheColorRed",
  "keywords": [
    "language-model-tools",
    "agent",
    "chat",
    "context",
    "crud",
    "rest",
    "data",
    "graphql",
    "mariadb",
    "mcp",
    "model",
    "mongodb",
    "mssql",
    "mysql",
    "postgres",
    "rest",
    "sqlite",
    "store",
    "s3",
    "azure-blob",
    "ftp",
    "redis"
  ],
  "icon": "images/icon.png",
  "type": "module",
  "engines": {
    "vscode": "^1.109.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/TheColorRed/data-store-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/TheColorRed/data-store-mcp/issues"
  },
  "categories": [
    "AI",
    "Chat",
    "Other"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished",
    "workspaceContains:.vscode/**/stores.json",
    "workspaceContains:.vscode/**/*.store.json",
    "workspaceContains:.vscode/**/connections.json",
    "workspaceContains:.vscode/**/*.connection.json"
  ],
  "contributes": {
    "jsonValidation": [
      {
        "fileMatch": ".vscode/**/{connections,stores}.json",
        "url": "./out/schemas/connections.schema.json"
      },
      {
        "fileMatch": ".vscode/**/*.{connection,store}.json",
        "url": "./out/schemas/connection.schema.json"
      }
    ],
    "chatInstructions": [
      {
        "path": "./out/docs/instructions/agents.instructions.md"
      },
      {
        "path": "./out/docs/instructions/connection.instructions.md"
      },
      {
        "path": "./out/docs/instructions/write-safety.instructions.md"
      },
      {
        "path": "./out/docs/instructions/security-secrets.instructions.md"
      }
    ],
    "chatSkills": [
      {
        "path": "./out/docs/skills/data-store-operations/SKILL.md"
      },
      {
        "path": "./out/docs/skills/data-store-document/SKILL.md"
      },
      {
        "path": "./out/docs/skills/data-store-ftp/SKILL.md"
      },
      {
        "path": "./out/docs/skills/data-store-graphql/SKILL.md"
      },
      {
        "path": "./out/docs/skills/data-store-key-value/SKILL.md"
      },
      {
        "path": "./out/docs/skills/data-store-rest/SKILL.md"
      },
      {
        "path": "./out/docs/skills/data-store-object-storage/SKILL.md"
      },
      {
        "path": "./out/docs/skills/data-store-sql/SKILL.md"
      }
    ],
    "mcpServerDefinitionProviders": [
      {
        "id": "data-store-mcp",
        "label": "Data Store"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile && npm run copy-schema && npm run copy-docs",
    "compile": "tsc -p ./",
    "prewatch": "rm -rf out && mkdir out && npm run copy-schema && npm run copy-docs",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "watch-json": "chokidar \"src/schemas/**/*.json\" -c \"npm run copy-schema\"",
    "copy-files": "npm run copy-schema && npm run copy-docs",
    "copy-schema": "cp -r \"src/schemas/\" out",
    "copy-docs": "cp -r \"src/docs/\" out"
  },
  "devDependencies": {
    "@types/mime-types": "^3.0.0",
    "@types/mssql": "^9.1.7",
    "@types/node": "22.x",
    "@types/pg": "^8.15.5",
    "@types/vscode": "^1.109.0",
    "@typescript-eslint/eslint-plugin": "^8.39.0",
    "@typescript-eslint/parser": "^8.39.0",
    "chokidar-cli": "^3.0.0",
    "eslint": "^9.32.0",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.864.0",
    "@aws-sdk/s3-request-presigner": "^3.864.0",
    "@azure/identity": "^4.13.0",
    "@azure/storage-blob": "^12.31.0",
    "@modelcontextprotocol/sdk": "1.17.1",
    "basic-ftp": "^5.0.5",
    "fast-glob": "^3.3.3",
    "graphql": "^16.11.0",
    "mime-types": "^3.0.2",
    "mongodb": "^6.18.0",
    "mssql": "^11.0.1",
    "mysql2": "^3.14.3",
    "node-sql-parser": "^5.3.10",
    "pg": "^8.16.3",
    "redis": "^5.11.0",
    "zod": "^3.25.76"
  }
}